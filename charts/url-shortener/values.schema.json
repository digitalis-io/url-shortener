{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "url-shortener Helm values",
  "type": "object",
  "required": ["replicaCount", "image", "app", "cassandra", "auth"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "app": {
      "type": "object",
      "required": ["publicBaseURL", "adminBaseURL"],
      "properties": {
        "httpAddr": {
          "type": "string"
        },
        "publicBaseURL": {
          "type": "string",
          "minLength": 1
        },
        "adminBaseURL": {
          "type": "string",
          "minLength": 1
        },
        "codeLength": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cassandra": {
      "type": "object",
      "required": ["hosts"],
      "properties": {
        "hosts": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["devBypass"],
      "properties": {
        "devBypass": {
          "type": "boolean"
        }
      }
    }
  }
}
